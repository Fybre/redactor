# Host port for web UI
HOST_PORT=8080

# Public base URL included in API responses (e.g. validation_url returned to Therefore).
# Must be reachable by the Therefore server and by the document reviewer's browser.
# Example: PUBLIC_BASE_URL=http://redactor.internal:8080
PUBLIC_BASE_URL=

# Worker concurrency (number of simultaneous redaction jobs)
WORKER_CONCURRENCY=2

# Folder polling
FOLDER_POLLING_ENABLED=true
POLL_INTERVAL_SECONDS=15

# File handling
MAX_FILE_SIZE_MB=100
RETAIN_ORIGINALS=true
RETENTION_DAYS=30

# Default redaction level: minimal, standard, aggressive, maximum
DEFAULT_REDACTION_LEVEL=standard

# Webhook defaults (can be overridden per-job)
DEFAULT_OUTPUT_MODE=directory

# Logging
LOG_LEVEL=INFO

# Set to false to prevent sensitive header values (Authorization, tokens, etc.)
# from being revealed in the UI once saved. Users must retype to update.
ALLOW_HEADER_REVEAL=true

# LLM detection (only used when Detection Strategy is set to "llm" or "both" in Settings)
# Model to pull on Ollama startup — change to llama3.1:8b or qwen2.5:7b for better accuracy
OLLAMA_MODEL=llama3.2:3b
